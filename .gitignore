# =========================
# Gradle / Spring Boot
# =========================
.gradle/
build/
out/

# Gradle Wrapper는 반드시 포함
!gradle/wrapper/gradle-wrapper.jar

# 혹시 src 내부에 build/out/bin 폴더를 의도적으로 둘 경우 예외
!**/src/main/**/build/
!**/src/test/**/build/
!**/src/main/**/out/
!**/src/test/**/out/
!**/src/main/**/bin/
!**/src/test/**/bin/


